# Server Configuration
PORT=5000

# MongoDB Connection String (Atlas or Local)
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/smart-bus-tracker
MONGO_URI=your_mongodb_connection_string_here

# JSON Web Token Secret (used for signing and verifying auth tokens)
# Generate a strong secret string (e.g., using `crypto.randomBytes(64).toString('hex')`)
JWT_SECRET=your_super_secret_jwt_key_here

# Firebase Cloud Messaging Server Key (for Push Notifications)
# Found in your Firebase Console -> Project Settings -> Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key_here
